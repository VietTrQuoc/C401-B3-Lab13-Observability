{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Day 13 Observability Lab Log Record",
  "type": "object",
  "required": ["ts", "level", "service", "event"],
  "additionalProperties": true,
  "properties": {
    "ts": {"type": "string", "minLength": 1},
    "level": {
      "type": "string",
      "enum": ["info", "warning", "error", "critical"]
    },
    "service": {"type": "string", "minLength": 1},
    "event": {"type": "string", "minLength": 1},
    "correlation_id": {"type": ["string", "null"], "minLength": 1},
    "env": {"type": ["string", "null"]},
    "user_id_hash": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{12}$"
    },
    "session_id": {"type": ["string", "null"]},
    "feature": {"type": ["string", "null"]},
    "model": {"type": ["string", "null"]},
    "latency_ms": {"type": ["integer", "null"], "minimum": 0},
    "tokens_in": {"type": ["integer", "null"], "minimum": 0},
    "tokens_out": {"type": ["integer", "null"], "minimum": 0},
    "cost_usd": {"type": ["number", "null"], "minimum": 0},
    "error_type": {"type": ["string", "null"]},
    "tool_name": {"type": ["string", "null"]},
    "payload": {"type": ["object", "null"]}
  },
  "allOf": [
    {
      "if": {
        "properties": {"service": {"const": "api"}},
        "required": ["service"]
      },
      "then": {
        "required": [
          "correlation_id",
          "env",
          "user_id_hash",
          "session_id",
          "feature",
          "model"
        ]
      }
    },
    {
      "if": {
        "properties": {"event": {"const": "response_sent"}},
        "required": ["event"]
      },
      "then": {
        "required": ["latency_ms", "tokens_in", "tokens_out", "cost_usd"]
      }
    },
    {
      "if": {
        "properties": {"event": {"const": "request_failed"}},
        "required": ["event"]
      },
      "then": {
        "required": ["error_type"]
      }
    }
  ]
}
